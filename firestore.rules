rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Проверка на аутентификацию
    function isAuth() {
      return request.auth != null;
    }
    
    // Проверка на администратора
    function isAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.civilnumber == '00010';
    }
    
    // Правила для коллекции users
    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() 
        && request.resource.data.status == 'pending'
        && request.resource.data.votingStatus == 'novote';
      allow update: if isAuth() 
        && (request.auth.uid == userId || isAdmin());
      allow delete: if isAuth() && isAdmin();
    }
    
    // Правила для коллекции votes
    match /votes/{voteId} {
      allow read: if true;
      allow write: if isAuth() && isAdmin();
      
      // Разрешаем голосование только если пользователь одобрен и еще не голосовал
      allow update: if isAuth() 
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status == 'approved'
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.votingStatus == 'novote';
    }
  }
}